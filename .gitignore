# Node Modules (These are huge and should be installed locally/in Docker, not pushed to GitHub)
node_modules/
*/node_modules/

# Environment Variables (CRITICAL: Never commit your database passwords!)
.env
.env.local
.env.development
.env.test
.env.production
*.env

# Frontend Build Artifacts (These are generated automatically by 'npm run build')
build/
frontend/build/
dist/

# NPM / Yarn Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# Operating System Files (Prevents clutter from Mac/Windows hidden files)
.DS_Store
Thumbs.db

# Editor/IDE Folders (VS Code, IntelliJ, etc.)
.vscode/
.idea/